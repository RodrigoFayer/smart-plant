@startuml leds
title LED output mapping — from plant state and sensor readings to LED colors

left to right direction

rectangle "Plant state\n(from backend)" as State {
    (happy) as H
    (thirsty / hot / noLight) as Y
    (sick) as S
    (unknown / sleeping) as U
}

rectangle "RGB LED 1\n(general status)" as LED1 {
    (GREEN) as G1
    (YELLOW) as Y1
    (RED) as R1
    (OFF) as O1
}

H --> G1
Y --> Y1
S --> R1
U --> O1

rectangle "Sensor readings" as Readings {
    (temp > 38°C) as T
    (ppm > 700) as P
    (soilMoisture < 20%) as D
    (rain detected) as R
    (all clear) as AC
}

rectangle "RGB LED 2\n(specific alert)" as LED2 {
    (RED) as R2
    (PURPLE) as PU2
    (YELLOW) as Y2
    (BLUE) as B2
    (OFF) as O2
}

note right of LED2
  Priority (top wins):
  1. temp  → RED
  2. ppm   → PURPLE
  3. soil  → YELLOW
  4. rain  → BLUE
end note

T --> R2
P --> PU2
D --> Y2
R --> B2
AC --> O2

rectangle "Moisture %" as Moisture {
    (0%) as M0
    (1–20%) as M1
    (21–60%) as M2
    (61–100%) as M3
}

rectangle "5-LED soil bar" as Bar {
    (0 LEDs — OFF) as B0
    (1 LED — RED) as B1
    (2–3 LEDs — YELLOW) as B23
    (4–5 LEDs — GREEN) as B45
}

M0 --> B0
M1 --> B1
M2 --> B23
M3 --> B45

@enduml
